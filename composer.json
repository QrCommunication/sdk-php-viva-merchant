{
    "name": "qrcommunication/viva-merchant-sdk",
    "description": "PHP SDK for Viva Wallet Merchant API — orders, transactions, sources, webhooks",
    "type": "library",
    "license": "MIT",
    "keywords": ["viva", "vivawallet", "payment", "merchant", "sdk"],
    "authors": [
        {
            "name": "QrCommunication",
            "email": "contact@qrcommunication.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "QrCommunication\\VivaMerchant\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "QrCommunication\\VivaMerchant\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
